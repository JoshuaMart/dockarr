# ----------------------------------------------------------------------------
# Dockarr — environment configuration
# Copy this file to `.env` and adjust the values, then run `make install`.
# ----------------------------------------------------------------------------

# --- User / system -----------------------------------------------------------
# UID/GID that own the config & media files. Run `id` on the host to find them.
PUID=1000
PGID=1000
TZ=Europe/Paris

# --- Storage paths -----------------------------------------------------------
# Where each service stores its configuration (databases, settings).
DOCKARR_CONFIG=./config

# Single shared tree for downloads + media so hardlinks / atomic moves work.
# Expected layout:
#   ${DOCKARR_DATA}/torrents        (qBittorrent download dir)
#   ${DOCKARR_DATA}/media/movies    (Radarr)
#   ${DOCKARR_DATA}/media/tv        (Sonarr)
#   ${DOCKARR_DATA}/media/books     (Kavita)
DOCKARR_DATA=./data

# --- Reverse proxy (Caddy) ---------------------------------------------------
# Base domain. Services are exposed as <service>.${DOCKARR_DOMAIN}
# e.g. radarr.dockarr.example.com. Use a real domain for automatic HTTPS.
DOCKARR_DOMAIN=dockarr.local
# Email used by Let's Encrypt for certificate notifications.
CADDY_EMAIL=you@example.com

# --- qBittorrent -------------------------------------------------------------
QBITTORRENT_WEBUI_PORT=8080

# --- Kavita ------------------------------------------------------------------
# Host port for Kavita. On macOS, AirPlay Receiver grabs :5000 — set 5001 here
# (or disable AirPlay Receiver in System Settings) for local use.
KAVITA_PORT=5000

# --- VPN (Gluetun) — optional, only used by docs/vpn instructions ------------
# Uncomment & fill these in only when you route qBittorrent through a VPN.
# VPN_SERVICE_PROVIDER=
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# SERVER_COUNTRIES=
